\f0\b\fs32 \cf0 The fix pattern (apply everywhere)\
\pard\pardeftab560\slleading20\partightenfactor0

\f1\b0\fs26 \cf0 For any aggregation query across all clinics:\
const PAGE_SIZE = 1000\
const allRows: Array<\{ /* relevant cols */ \}> = []\
let offset = 0\
\
while (true) \{\
  const \{ data, error \} = await supabase\
    .from('clinics')\
    .select('your_columns')\
    .eq('is_iv_clinic', true)\
    .eq('enrichment_status', 'enriched')\
    .is('duplicate_of', null)\
    // ... other filters\
    .range(offset, offset + PAGE_SIZE - 1)\
\
  if (error || !data || data.length === 0) break\
  allRows.push(...(data as any))\
  if (data.length < PAGE_SIZE) break\
  offset += PAGE_SIZE\
\}\
Standard filter triple for "directory-visible" clinics:\
